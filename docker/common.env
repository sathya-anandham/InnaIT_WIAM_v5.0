ORACLE_URL=jdbc:oracle:thin:@innait-oracle-db:1521/FREEPDB1
ORACLE_USER=wiam
SPRING_PROFILES_ACTIVE=prod

# Redis — Spring Boot relaxed-binding name (works even without yml config)
REDIS_HOST=innait-redis
REDIS_PORT=6379
SPRING_DATA_REDIS_HOST=innait-redis
SPRING_DATA_REDIS_PORT=6379

# Kafka — both naming conventions used across services
KAFKA_BROKERS=innait-kafka:9092
KAFKA_BOOTSTRAP=innait-kafka:9092
SPRING_KAFKA_BOOTSTRAP_SERVERS=innait-kafka:9092

JWKS_URL=http://innait-token-service:8086/.well-known/jwks.json
JWT_ISSUER=http://innait-token-service:8086

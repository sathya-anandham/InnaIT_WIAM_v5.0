    "@innait/core": {
      "projectType": "library",
      "root": "projects/innait/core",
      "sourceRoot": "projects/innait/core/src",
      "prefix": "innait",
      "architect": {
        "build": {
          "builder": "ng-packagr:build",
          "options": { "project": "projects/innait/core/ng-package.json" },
          "configurations": {
            "production": { "tsConfig": "projects/innait/core/tsconfig.lib.prod.json" },

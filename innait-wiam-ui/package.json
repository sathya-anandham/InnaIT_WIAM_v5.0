{
  "name": "innait-wiam-ui",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start:login": "ng serve login-portal --port 4200",
    "start:self-service": "ng serve self-service-portal --port 4201",
    "start:admin": "ng serve admin-console --port 4202",
    "build:login": "ng build login-portal --configuration production",
    "build:self-service": "ng build self-service-portal --configuration production",
    "build:admin": "ng build admin-console --configuration production",
    "build:all": "npm run build:login && npm run build:self-service && npm run build:admin",
    "build:libs": "ng build @innait/core && ng build @innait/ui && ng build @innait/i18n",
    "test": "ng test",
    "test:core": "ng test @innait/core",
    "test:ui": "ng test @innait/ui",
    "test:login": "ng test login-portal",
    "test:self-service": "ng test self-service-portal",
    "test:admin": "ng test admin-console",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\""
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "primeng": "^17.18.0",
    "primeicons": "^7.0.0",
    "primeflex": "^3.3.1",
    "ag-grid-angular": "^32.0.0",
    "ag-grid-community": "^32.0.0",
    "chart.js": "^4.4.0",
    "ng2-charts": "^6.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "typescript": "~5.4.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^18.2.0",
    "angular-eslint": "^18.0.0",
    "@angular-eslint/builder": "^18.0.0",
    "@angular-eslint/eslint-plugin": "^18.0.0",
    "@angular-eslint/eslint-plugin-template": "^18.0.0",
    "@angular-eslint/schematics": "^18.0.0",
    "@angular-eslint/template-parser": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  }
}
